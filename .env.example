# ── .env.example ─────────────────────────────────────────────────────────────
# Copy to `.env` and fill in your values. Never commit the real `.env`.

# GitHub Personal Access Token (raises rate limit from 60 → 5000 req/h)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Vertex AI setup (Bypasses AI Studio quotas, uses GCP project billing)
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ── Google Cloud (needed for Cloud Run deployment + Vertex AI Memory) ────────
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GCP_REGION=us-central1

# ── Vertex AI Memory Bank (populate after running deploy_memory.py) ──────────
AGENT_ENGINE_ID=
